<launch>
  <arg name="node_name_suffix" default="test" description="node name suffix"/>
  <arg name="topic_name" default="/test" description="output topic name"/>
  <arg name="topic_type" default="std_msgs::msg::String" description="output topic type"/>
  <arg name="topic_value_yaml_path" default="$(find-pkg-share autoware_dummy_topic_publisher)/config/topic_value.yaml" description="output topic value"/>
  <arg name="qos" default="1" description="QoS profile"/>
  <arg name="transient_local" default="false" description="add transient_local option to publisher or not"/>
  <arg name="best_effort" default="false" description="add best_effort option to publisher or not"/>
  <arg name="rate" default="10" description="update rate for topic publish"/>

  <node pkg="autoware_dummy_topic_publisher" exec="autoware_dummy_topic_publisher_node" name="dummy_topic_publisher_$(var node_name_suffix)" output="screen">
    <param name="topic_name" value="$(var topic_name)"/>
    <param name="topic_type" value="$(var topic_type)"/>
    <param name="topic_value_yaml_path" value="$(var topic_value_yaml_path)"/>
    <param name="qos" value="$(var qos)"/>
    <param name="transient_local" value="$(var transient_local)"/>
    <param name="best_effort" value="$(var best_effort)"/>
    <param name="rate" value="$(var rate)"/>
  </node>
</launch>
